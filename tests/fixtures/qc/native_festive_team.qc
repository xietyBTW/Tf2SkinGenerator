// Натив-праздничная модель (отдельный c_*_xmas.mdl): база и BLU оканчиваются
// на _xmas. festive — это база, а не overlay-вариант → ложной карточки
// варианта быть не должно, но команда RED/BLU работает.
$texturegroup "skinfamilies"
{
	{ "c_sapper_xmas"      "c_sapper_xmas_blue" "c_sapper" "v_sapper_glass" }
	{ "c_sapper_xmas_blue" "c_sapper_xmas_blue" "c_sapper" "v_sapper_glass" }
}
