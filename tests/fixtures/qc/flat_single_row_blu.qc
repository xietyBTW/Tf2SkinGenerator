// Valve иногда пишет все скины в ОДНУ строку (BLU-имена как столбцы) —
// такие имена не должны попадать в extra_materials
$texturegroup "skinfamilies"
{
	{ "c_flamethrower" "c_flamethrower_shell" "c_flamethrower_blue" "c_flamethrower_shell_blue" }
	{ "c_flamethrower_blue" "c_flamethrower_shell_blue" "c_flamethrower_blue" "c_flamethrower_shell_blue" }
}
