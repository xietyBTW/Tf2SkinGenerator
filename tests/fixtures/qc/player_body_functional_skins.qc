// Тело персонажа: команда RED/BLU + функциональные скины (убер invun и т.п.),
// которые НЕ являются косметическими стилями. selector_spec.styles должен быть
// пуст (генерик «Skin N» не косметика), но команда определяется.
$texturegroup "skinfamilies"
{
	{ "spy_red"       }
	{ "spy_blue"      }
	{ "spy_red_invun" }
	{ "spy_blue_invun" }
}
